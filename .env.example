# Required: get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model
ANTHROPIC_MODEL=claude-sonnet-5

# Optional but recommended: raises your NCBI E-utilities rate limit from 3 to 10 req/sec
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=

# Required for the web app (web/app.py): gates every page behind HTTP Basic
# Auth so a stranger with the URL can't trigger runs on your Anthropic bill.
SITE_USERNAME=
SITE_PASSWORD=
