# Required: get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model
ANTHROPIC_MODEL=claude-sonnet-5

# Optional but recommended: raises your NCBI E-utilities rate limit from 3 to 10 req/sec
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=

# Required for the web app (web/app.py): every page requires logging in at
# /login so a stranger with the URL can't trigger runs on your Anthropic
# bill. SITE_USERNAME/SITE_PASSWORD is the password-login fallback.
SITE_USERNAME=
SITE_PASSWORD=

# Required for the web app: signs the login session cookie. Generate one
# with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Optional: enables "Sign in with Google" on the login page (in addition to
# the username/password fallback above). Leave blank to skip Google login
# entirely. See README.md for the Google Cloud Console setup steps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The only email allowed to sign in via Google (required if the two vars above are set).
ALLOWED_EMAIL=

# Optional: makes run history (web/db.py) persist across deploys/restarts.
# Leave blank to use a local SQLite file instead - fine for local dev, but
# on Render's free tier (no persistent disk) that file resets on every
# redeploy and idle-restart. A free Postgres project (e.g. neon.tech) fixes
# that; paste its connection string here. See README.md for setup steps.
DATABASE_URL=
